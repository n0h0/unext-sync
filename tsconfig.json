{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "chrome", "@cloudflare/workers-types"]
  },
  "include": ["shared", "extension"]
}
